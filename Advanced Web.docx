/* ============================================
   ELYSEE HOME STORE - Stylesheet
   Aesthetic: Luxury Editorial / Warm Minimal
============================================ */

:root {
    --cream:    #F7F4EF;
    --warm-white: #FDFCF9;
    --sand:     #E8E0D0;
    --taupe:    #C4B89A;
    --brown:    #8B6E52;
    --espresso: #3D2B1F;
    --charcoal: #2A2420;
    --gold:     #C9A96E;
    --gold-light: #E4C99A;
    --sage:     #7A8C6E;
    --terracotta: #C07A5A;
    --error:    #C0392B;
    --success:  #27AE60;

    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body:    'DM Sans', system-ui, sans-serif;

    --radius:   12px;
    --radius-sm: 6px;
    --shadow:   0 4px 24px rgba(61,43,31,0.10);
    --shadow-lg: 0 12px 48px rgba(61,43,31,0.16);
    --nav-h:    72px;
    --transition: 0.28s cubic-bezier(0.4,0,0.2,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
    font-family: var(--font-body);
    background: var(--warm-white);
    color: var(--charcoal);
    font-size: 15px;
    line-height: 1.6;
    overflow-x: hidden;
}

/* ===== TYPOGRAPHY ===== */
h1,h2,h3,h4 { font-family: var(--font-display); font-weight: 400; line-height: 1.15; }
h1 { font-size: clamp(2.8rem, 6vw, 5rem); }
h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); }
h3 { font-size: 1.4rem; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; border: none; background: none; font-family: inherit; }
img { display: block; width: 100%; object-fit: cover; }
input, select, textarea { font-family: var(--font-body); font-size: 14px; }

/* ===== BUTTONS ===== */
.btn-primary {
    background: var(--espresso);
    color: var(--cream);
    padding: 13px 28px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: var(--transition);
    display: inline-flex; align-items: center; gap: 8px;
}
.btn-primary:hover { background: var(--brown); transform: translateY(-1px); box-shadow: var(--shadow); }
.btn-outline {
    border: 1.5px solid var(--espresso);
    color: var(--espresso);
    padding: 11px 24px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 500;
    transition: var(--transition);
    background: transparent;
}
.btn-outline:hover { background: var(--espresso); color: var(--cream); }
.btn-ghost {
    color: var(--espresso);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 12px 0;
    background: none;
    border: none;
    transition: color var(--transition);
}
.btn-ghost:hover { color: var(--brown); }
.full-width { width: 100%; justify-content: center; }

/* ===== NAVBAR ===== */
.navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(253,252,249,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--sand);
    transition: box-shadow var(--transition);
}
.navbar.scrolled { box-shadow: var(--shadow); }
.nav-inner {
    max-width: 1400px; margin: 0 auto;
    display: flex; align-items: center; gap: 24px;
    padding: 0 32px; height: var(--nav-h);
}
.logo { display: flex; align-items: center; gap: 8px; white-space: nowrap; }
.logo-mark { color: var(--gold); font-size: 18px; }
.logo-text { font-family: var(--font-display); font-size: 1.6rem; color: var(--espresso); letter-spacing: 0.04em; }
.nav-links { display: flex; gap: 4px; flex: 1; justify-content: center; }
.nav-links a {
    padding: 8px 14px; border-radius: 50px; font-size: 13.5px;
    color: var(--charcoal); font-weight: 400; transition: var(--transition);
}
.nav-links a:hover { background: var(--sand); color: var(--espresso); }
.nav-actions { display: flex; align-items: center; gap: 16px; }

.search-wrap { position: relative; }
.search-wrap input {
    background: var(--cream); border: 1.5px solid var(--sand);
    border-radius: 50px; padding: 8px 36px 8px 16px;
    width: 200px; font-size: 13.5px; color: var(--charcoal);
    transition: var(--transition);
}
.search-wrap input:focus { outline: none; border-color: var(--taupe); width: 240px; }
.search-icon { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--taupe); font-size: 18px; pointer-events: none; }

.cart-btn {
    position: relative; padding: 8px; border-radius: 50%;
    color: var(--espresso); transition: var(--transition);
    display: flex; align-items: center;
}
.cart-btn:hover { background: var(--sand); }
.cart-count {
    position: absolute; top: 0; right: 0;
    background: var(--gold); color: var(--espresso);
    border-radius: 50%; width: 18px; height: 18px;
    font-size: 10px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
}
.cart-count:empty, .cart-count[data-count="0"] { display: none; }

.user-menu { position: relative; }
.user-dropdown {
    position: absolute; right: 0; top: calc(100% + 8px);
    background: white; border: 1px solid var(--sand);
    border-radius: var(--radius); padding: 8px;
    min-width: 180px; box-shadow: var(--shadow-lg);
    display: flex; flex-direction: column; gap: 4px;
}
.user-dropdown span { font-family: var(--font-display); font-size: 1rem; padding: 8px 12px; color: var(--espresso); font-weight: 600; }
.user-dropdown button { padding: 8px 12px; border-radius: var(--radius-sm); text-align: left; font-size: 13.5px; transition: var(--transition); }
.user-dropdown button:hover { background: var(--cream); }
.hamburger { display: none; font-size: 22px; color: var(--espresso); }

.mobile-menu {
    display: none; flex-direction: column;
    padding: 16px 24px; gap: 4px;
    border-top: 1px solid var(--sand);
    background: var(--warm-white);
}
.mobile-menu a { padding: 12px 0; font-size: 15px; border-bottom: 1px solid var(--sand); }
.mobile-menu.open { display: flex; }

/* ===== SECTIONS ===== */
.section { display: none; padding-top: var(--nav-h); min-height: 100vh; }
.section.active { display: block; }

/* ===== HERO ===== */
.hero {
    min-height: calc(100vh - var(--nav-h));
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center; gap: 0;
    max-width: 1400px; margin: 0 auto;
    padding: 60px 80px; position: relative; overflow: hidden;
}
.hero-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.hero-shape {
    position: absolute; border-radius: 50%;
    opacity: 0.15;
}
.shape-1 { width: 600px; height: 600px; background: radial-gradient(var(--gold), transparent 70%); top: -200px; right: -100px; }
.shape-2 { width: 400px; height: 400px; background: radial-gradient(var(--taupe), transparent 70%); bottom: -100px; left: -100px; }
.shape-3 { width: 200px; height: 200px; background: radial-gradient(var(--terracotta), transparent 70%); top: 40%; left: 40%; }

.hero-content { z-index: 1; }
.hero-eyebrow {
    font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gold); font-weight: 500; margin-bottom: 20px;
    display: flex; align-items: center; gap: 10px;
}
.hero-eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--gold); }
.hero-title {
    color: var(--espresso); margin-bottom: 24px; animation: fadeUp 0.7s ease both;
}
.hero-title em { font-style: italic; color: var(--brown); }
.hero-sub { font-size: 16px; color: #6B5B50; max-width: 380px; margin-bottom: 40px; line-height: 1.7; }
.hero-cta { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

.hero-image { z-index: 1; display: flex; justify-content: center; }
.hero-img-frame {
    position: relative; border-radius: 24px; overflow: hidden;
    width: 100%; max-width: 520px;
    box-shadow: var(--shadow-lg);
    animation: fadeIn 0.9s ease both 0.2s;
}
.hero-img-frame img { height: 520px; object-position: center; }
.hero-tag {
    position: absolute; bottom: 24px; left: 24px;
    background: rgba(253,252,249,0.92); backdrop-filter: blur(12px);
    border-radius: var(--radius); padding: 12px 18px;
    display: flex; flex-direction: column; gap: 2px;
    box-shadow: var(--shadow);
}
.tag-label { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); font-weight: 600; }
.tag-name { font-family: var(--font-display); font-size: 1rem; color: var(--espresso); }
.tag-price { font-size: 13px; font-weight: 600; color: var(--brown); }

/* ===== CATEGORIES STRIP ===== */
.categories-strip {
    display: flex; gap: 16px; justify-content: center;
    padding: 40px 80px; background: var(--cream);
    border-top: 1px solid var(--sand); border-bottom: 1px solid var(--sand);
    flex-wrap: wrap;
}
.cat-card {
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    padding: 28px 40px; border-radius: var(--radius);
    background: white; border: 1.5px solid var(--sand);
    cursor: pointer; transition: var(--transition); min-width: 140px;
}
.cat-card:hover { border-color: var(--taupe); box-shadow: var(--shadow); transform: translateY(-2px); }
.cat-icon { font-size: 32px; }
.cat-card span { font-size: 14px; font-weight: 500; color: var(--espresso); }

/* ===== SECTION BLOCK ===== */
.section-block { max-width: 1400px; margin: 0 auto; padding: 80px 80px; }
.section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 40px; }
.section-title { color: var(--espresso); }
.see-all { color: var(--brown); font-size: 14px; font-weight: 500; }
.see-all:hover { text-decoration: underline; }

/* ===== PRODUCTS GRID ===== */
.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
}

/* ===== PRODUCT CARD ===== */
.product-card {
    background: white; border-radius: var(--radius);
    border: 1px solid var(--sand); overflow: hidden;
    transition: var(--transition); cursor: pointer;
    display: flex; flex-direction: column;
    animation: fadeUp 0.5s ease both;
}
.product-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--taupe); }
.product-card:nth-child(1) { animation-delay: 0.05s; }
.product-card:nth-child(2) { animation-delay: 0.1s; }
.product-card:nth-child(3) { animation-delay: 0.15s; }
.product-card:nth-child(4) { animation-delay: 0.2s; }

.product-image-wrap {
    position: relative; overflow: hidden; aspect-ratio: 4/3;
    background: var(--cream);
}
.product-image-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.product-card:hover .product-image-wrap img { transform: scale(1.04); }
.product-badge {
    position: absolute; top: 12px; left: 12px;
    background: var(--espresso); color: var(--gold-light);
    font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 4px 10px; border-radius: 50px;
}
.product-badge.new { background: var(--sage); color: white; }
.product-badge.premium { background: var(--gold); color: var(--espresso); }
.quick-add {
    position: absolute; bottom: 12px; right: 12px;
    background: white; color: var(--espresso);
    width: 38px; height: 38px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: var(--transition);
    box-shadow: var(--shadow); font-size: 18px;
}
.product-card:hover .quick-add { opacity: 1; }
.quick-add:hover { background: var(--espresso); color: white; }

.product-info { padding: 18px 20px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
.product-cat { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--taupe); }
.product-name { font-family: var(--font-display); font-size: 1.15rem; color: var(--espresso); }
.product-price { font-size: 15px; font-weight: 600; color: var(--brown); margin-top: auto; }
.product-desc { font-size: 12.5px; color: #8A7060; line-height: 1.5; }

.product-actions { display: flex; gap: 8px; padding: 0 20px 20px; }
.product-actions .btn-primary { flex: 1; padding: 10px 16px; font-size: 13px; }
.product-actions .btn-outline { padding: 10px 14px; font-size: 13px; }

/* ===== PROMO BANNER ===== */
.promo-banner {
    background: var(--espresso); color: var(--cream);
    padding: 80px 80px; text-align: center;
    position: relative; overflow: hidden;
}
.promo-banner::before {
    content: '✦'; font-size: 300px; position: absolute;
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    opacity: 0.04; font-family: serif; pointer-events: none;
}
.promo-content { position: relative; max-width: 540px; margin: 0 auto; }
.promo-content h2 { color: var(--gold-light); font-size: clamp(1.6rem,3vw,2.4rem); margin-bottom: 16px; }
.promo-content p { color: rgba(247,244,239,0.7); margin-bottom: 32px; font-size: 16px; }

/* ===== CATALOG ===== */
.catalog-layout {
    max-width: 1400px; margin: 0 auto;
    display: grid; grid-template-columns: 220px 1fr;
    gap: 48px; padding: 60px 80px;
    align-items: start;
}
.catalog-sidebar { position: sticky; top: calc(var(--nav-h) + 24px); }
.catalog-sidebar h3 { font-family: var(--font-display); font-size: 1.1rem; margin-bottom: 24px; color: var(--espresso); }
.filter-group { margin-bottom: 28px; }
.filter-label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--taupe); margin-bottom: 10px; font-weight: 500; }
.filter-btn {
    display: block; width: 100%; text-align: left;
    padding: 9px 14px; border-radius: var(--radius-sm);
    font-size: 14px; color: var(--charcoal);
    margin-bottom: 4px; transition: var(--transition);
}
.filter-btn:hover { background: var(--cream); }
.filter-btn.active { background: var(--espresso); color: var(--cream); }
.filter-group select {
    width: 100%; padding: 9px 14px;
    border: 1.5px solid var(--sand); border-radius: var(--radius-sm);
    background: white; color: var(--charcoal);
    appearance: none; cursor: pointer;
}
.catalog-topbar { display: flex; align-items: baseline; gap: 16px; margin-bottom: 32px; }
.catalog-topbar h2 { color: var(--espresso); }
.product-count { font-size: 13px; color: var(--taupe); }

/* ===== CART ===== */
.page-header { max-width: 1200px; margin: 0 auto; padding: 48px 80px 0; }
.page-header h2 { color: var(--espresso); }
.cart-layout { max-width: 1200px; margin: 0 auto; padding: 40px 80px 80px; display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
.cart-items { display: flex; flex-direction: column; gap: 16px; }
.cart-item {
    display: flex; align-items: center; gap: 20px;
    background: white; border: 1px solid var(--sand);
    border-radius: var(--radius); padding: 16px 20px;
}
.cart-item-img { width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-sm); flex-shrink: 0; }
.cart-item-info { flex: 1; }
.cart-item-name { font-family: var(--font-display); font-size: 1.05rem; color: var(--espresso); margin-bottom: 4px; }
.cart-item-price { font-size: 14px; color: var(--brown); font-weight: 600; }
.cart-item-controls { display: flex; align-items: center; gap: 8px; margin-top: 10px; }
.qty-btn { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--sand); display: flex; align-items: center; justify-content: center; font-size: 16px; transition: var(--transition); }
.qty-btn:hover { border-color: var(--espresso); }
.qty-val { min-width: 28px; text-align: center; font-size: 14px; font-weight: 600; }
.cart-item-remove { margin-left: auto; color: var(--taupe); font-size: 18px; transition: color var(--transition); }
.cart-item-remove:hover { color: var(--error); }

.cart-summary {
    background: white; border: 1px solid var(--sand);
    border-radius: var(--radius); padding: 28px; position: sticky;
    top: calc(var(--nav-h) + 24px);
}
.cart-summary h3 { font-family: var(--font-display); font-size: 1.3rem; color: var(--espresso); margin-bottom: 20px; }
.summary-row { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 12px; }
.summary-row.total { font-size: 16px; font-weight: 600; border-top: 1px solid var(--sand); padding-top: 14px; margin-top: 8px; }
.empty-cart { text-align: center; padding: 80px 24px; grid-column: 1/-1; }
.empty-cart .empty-icon { font-size: 56px; margin-bottom: 20px; }
.empty-cart h3 { font-family: var(--font-display); font-size: 1.6rem; margin-bottom: 12px; color: var(--espresso); }
.empty-cart p { color: var(--taupe); margin-bottom: 28px; }

/* ===== AUTH ===== */
.auth-container {
    min-height: calc(100vh - var(--nav-h));
    display: grid; grid-template-columns: 1fr 1fr;
}
.auth-art { position: relative; overflow: hidden; }
.auth-art img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
.auth-art-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(61,43,31,0.75), rgba(61,43,31,0.4));
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 60px;
}
.auth-logo { font-family: var(--font-display); font-size: 2rem; color: var(--gold-light); margin-bottom: 16px; }
.auth-art-overlay p { font-family: var(--font-display); font-size: 1.8rem; color: var(--cream); line-height: 1.3; }

.auth-form-side {
    display: flex; flex-direction: column; justify-content: center;
    padding: 80px 60px; background: var(--warm-white);
}
.auth-tabs { display: flex; gap: 0; margin-bottom: 40px; border-bottom: 1.5px solid var(--sand); }
.auth-tab {
    padding: 10px 24px; font-size: 15px; font-weight: 500;
    color: var(--taupe); border-bottom: 2px solid transparent;
    transition: var(--transition); margin-bottom: -1.5px;
}
.auth-tab.active { color: var(--espresso); border-bottom-color: var(--espresso); }

.auth-form h2 { font-family: var(--font-display); color: var(--espresso); margin-bottom: 6px; font-size: 2rem; }
.form-sub { color: var(--taupe); font-size: 14px; margin-bottom: 32px; }
.field-group { margin-bottom: 20px; }
.field-group label { display: block; font-size: 12.5px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--brown); margin-bottom: 8px; }
.field-group input, .field-group select, .field-group textarea {
    width: 100%; padding: 12px 16px;
    border: 1.5px solid var(--sand); border-radius: var(--radius-sm);
    background: white; color: var(--charcoal);
    transition: var(--transition);
}
.field-group input:focus, .field-group select:focus, .field-group textarea:focus {
    outline: none; border-color: var(--taupe);
    box-shadow: 0 0 0 3px rgba(196,184,154,0.15);
}
.field-group input.error { border-color: var(--error); }
.field-error { display: block; font-size: 12px; color: var(--error); margin-top: 5px; min-height: 16px; }
.password-wrap { position: relative; }
.toggle-pw {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    font-size: 12px; font-weight: 500; color: var(--taupe);
    background: none; border: none; cursor: pointer;
}
.pw-strength { height: 4px; border-radius: 2px; margin-top: 8px; transition: width var(--transition); background: var(--sand); }
.pw-strength.weak   { background: var(--error); width: 33%; }
.pw-strength.medium { background: var(--gold); width: 66%; }
.pw-strength.strong { background: var(--success); width: 100%; }
.form-switch { display: block; text-align: center; margin-top: 20px; font-size: 13.5px; color: var(--taupe); }
.form-switch a { color: var(--brown); font-weight: 500; }

/* ===== ADMIN ===== */
.admin-container { max-width: 1200px; margin: 0 auto; padding: 60px 80px; }
.admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
.admin-header h2 { color: var(--espresso); }
.admin-table-wrap { overflow-x: auto; border-radius: var(--radius); border: 1px solid var(--sand); }
.admin-table { width: 100%; border-collapse: collapse; }
.admin-table th { background: var(--cream); padding: 14px 18px; text-align: left; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--taupe); font-weight: 600; border-bottom: 1px solid var(--sand); }
.admin-table td { padding: 14px 18px; border-bottom: 1px solid var(--sand); font-size: 13.5px; vertical-align: middle; }
.admin-table tr:last-child td { border-bottom: none; }
.admin-table tr:hover td { background: var(--cream); }
.admin-table img { width: 56px; height: 56px; object-fit: cover; border-radius: var(--radius-sm); }
.btn-edit { color: var(--brown); font-size: 12.5px; font-weight: 500; border: 1px solid var(--sand); padding: 5px 12px; border-radius: 50px; transition: var(--transition); }
.btn-edit:hover { background: var(--cream); }
.btn-del { color: var(--error); font-size: 12.5px; font-weight: 500; border: 1px solid #e8cccc; padding: 5px 12px; border-radius: 50px; transition: var(--transition); }
.btn-del:hover { background: #fde8e8; }
.admin-actions { display: flex; gap: 8px; }

/* ===== MODALS ===== */
.modal-overlay {
    position: fixed; inset: 0; z-index: 2000;
    background: rgba(42,36,32,0.55); backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    padding: 24px;
}
.modal-overlay.open { display: flex; }
.modal-box {
    background: white; border-radius: 20px;
    box-shadow: var(--shadow-lg); position: relative;
    max-height: 90vh; overflow-y: auto; animation: popIn 0.25s ease;
}
.detail-modal { max-width: 800px; width: 100%; }
.form-modal { max-width: 540px; width: 100%; padding: 40px; }
.form-modal h3 { font-family: var(--font-display); font-size: 1.5rem; color: var(--espresso); margin-bottom: 28px; }
.modal-close {
    position: absolute; top: 16px; right: 16px;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--cream); color: var(--charcoal);
    font-size: 14px; display: flex; align-items: center; justify-content: center;
    z-index: 1; transition: var(--transition);
}
.modal-close:hover { background: var(--sand); }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; }
.detail-img { height: 400px; object-fit: cover; }
.detail-info { padding: 48px 40px; display: flex; flex-direction: column; gap: 12px; }
.detail-cat { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--taupe); }
.detail-name { font-family: var(--font-display); font-size: 1.8rem; color: var(--espresso); }
.detail-price { font-size: 1.5rem; color: var(--brown); font-weight: 600; }
.detail-desc { font-size: 14px; color: #6B5B50; line-height: 1.7; }
.detail-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: auto; padding-top: 16px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 8px; }

/* ===== FOOTER ===== */
.footer { background: var(--espresso); color: var(--cream); }
.footer-inner {
    max-width: 1400px; margin: 0 auto;
    padding: 80px 80px 48px;
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
}
.footer-brand .logo-text { color: var(--gold-light); }
.footer-brand .logo-mark { color: var(--gold); }
.footer-brand p { font-size: 13.5px; color: rgba(247,244,239,0.55); margin-top: 16px; line-height: 1.7; }
.footer-links h4 { font-family: var(--font-display); font-size: 1rem; color: var(--gold-light); margin-bottom: 18px; }
.footer-links a { display: block; font-size: 13.5px; color: rgba(247,244,239,0.6); margin-bottom: 10px; transition: color var(--transition); }
.footer-links a:hover { color: var(--cream); }
.footer-bottom { border-top: 1px solid rgba(247,244,239,0.1); padding: 24px 80px; text-align: center; }
.footer-bottom p { font-size: 12.5px; color: rgba(247,244,239,0.35); }

/* ===== TOAST ===== */
.toast {
    position: fixed; bottom: 32px; right: 32px; z-index: 3000;
    background: var(--espresso); color: var(--cream);
    padding: 14px 22px; border-radius: var(--radius-sm);
    font-size: 14px; max-width: 300px; box-shadow: var(--shadow-lg);
    transform: translateY(20px); opacity: 0;
    transition: all 0.3s ease; pointer-events: none;
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.success { background: var(--espresso); border-left: 3px solid var(--gold); }
.toast.error { background: #2d0a0a; border-left: 3px solid var(--error); }

/* ===== UTILITY ===== */
.loading-spinner { text-align: center; padding: 60px 24px; color: var(--taupe); font-size: 14px; }
.no-results { text-align: center; padding: 80px 24px; color: var(--taupe); font-family: var(--font-display); font-size: 1.3rem; }

/* ===== ANIMATIONS ===== */
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
}
@keyframes popIn {
    from { opacity: 0; transform: scale(0.94) translateY(12px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1100px) {
    .hero { padding: 40px 48px; gap: 32px; }
    .section-block { padding: 60px 48px; }
    .catalog-layout { padding: 40px 48px; }
    .cart-layout { padding: 32px 48px; }
    .admin-container { padding: 40px 48px; }
    .footer-inner { padding: 60px 48px 40px; }
    .footer-bottom { padding: 20px 48px; }
    .categories-strip { padding: 40px 48px; }
    .promo-banner { padding: 60px 48px; }
}
@media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; text-align: center; }
    .hero-eyebrow { justify-content: center; }
    .hero-sub { margin: 0 auto 40px; }
    .hero-cta { justify-content: center; }
    .hero-image { display: none; }
    .nav-links { display: none; }
    .search-wrap { display: none; }
    .hamburger { display: block; }
    .catalog-layout { grid-template-columns: 1fr; }
    .catalog-sidebar { position: static; display: flex; gap: 24px; flex-wrap: wrap; align-items: center; }
    .catalog-sidebar h3 { width: 100%; }
    .filter-group { margin-bottom: 0; }
    .auth-container { grid-template-columns: 1fr; }
    .auth-art { display: none; }
    .cart-layout { grid-template-columns: 1fr; }
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .detail-grid { grid-template-columns: 1fr; }
    .detail-img { height: 280px; }
    .form-row { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
    :root { --nav-h: 60px; }
    .nav-inner { padding: 0 20px; }
    .hero { padding: 32px 24px; }
    .section-block { padding: 40px 24px; }
    .catalog-layout { padding: 24px; }
    .categories-strip { padding: 32px 24px; }
    .page-header { padding: 32px 24px 0; }
    .cart-layout { padding: 24px; }
    .admin-container { padding: 24px; }
    .auth-form-side { padding: 40px 24px; }
    .footer-inner { grid-template-columns: 1fr; padding: 48px 24px 32px; }
    .footer-bottom { padding: 16px 24px; }
    .promo-banner { padding: 48px 24px; }
    .form-modal { padding: 28px 24px; }
}
